{##############################################################################}
{ Generic Pascal Header Template (Generated by C2Pas-Jinja)                    }
{##############################################################################}

unit {{ header | replace('.h', '') | pas_name }};

{$ALIGN 8}
{$MINENUMSIZE 4}
{$WEAKPACKAGEUNIT ON}

interface

uses
  System.SysUtils;

{==============================================================================}
{ TYPES AND ALIASES                                                            }
{==============================================================================}
{% if types %}
type
{% for t in types %}
{% if t.collision_with %}
  // Delphi collision with {{ t.collision_with }}:
  // type {{ t.name }} ...
{% elif t.kind == 'alias' %}
  {{ t.name | pas_name }} = {{ t.parent_type | pas_type }};
  P{{ t.name }} = ^{{ t.name | pas_name }};
{% elif t.kind == 'struct' or t.kind == 'union' %}
  {% if t.is_opaque %}
  P{{ t.name }} = Pointer;
  {% else %}
  {{ t.name | pas_name }} = record
    // Extractor struct parsing logic will go here
  end;
  P{{ t.name }} = ^{{ t.name | pas_name }};
  {% endif %}
{% endif %}
{% endfor %}
{% endif %}

{==============================================================================}
{ ENUMERATIONS                                                                 }
{==============================================================================}
{% if enums %}
type
{% for e in enums %}
{% if not e.collision_with %}
  {{ e.name | pas_name }} = Integer;
{% endif %}
{% endfor %}
{% endif %}

{==============================================================================}
{ CALLBACKS (FUNCTION POINTERS)                                                }
{==============================================================================}
{% if callbacks %}
type
{% for c in callbacks %}
{% if not c.collision_with %}
  {{ c.name | pas_name }} = {{ c | pas_sig(is_var=True) }};
{% endif %}
{% endfor %}
{% endif %}

{==============================================================================}
{ CONSTANTS                                                                    }
{==============================================================================}
{% if constants %}
const
{% for c in constants %}
{% if c.value and not c.collision_with %}
  {{ c.name | pas_name }} = {{ c.value | pas_expression }};
{% endif %}
{% endfor %}
{% endif %}

{==============================================================================}
{ ROUTINES                                                                     }
{==============================================================================}
{% if routines %}
{% for r in routines %}
{% if not r.collision_with %}
{{ r | pas_sig(is_var=False) }};
{$EXTERNALSYM {{ r.name }}}
{% endif %}
{% endfor %}
{% endif %}

{==============================================================================}
{ MACROS AND INLINE ROUTINES                                                   }
{==============================================================================}
{% if static_routines %}
{% for r in static_routines %}
{% if not r.collision_with %}
{{ r | pas_sig(is_var=False) }}; inline;
{% endif %}
{% endfor %}
{% endif %}

implementation

{% if static_routines %}
{==============================================================================}
{ MACROS AND INLINE ROUTINES IMPLEMENTATION                                    }
{==============================================================================}
{% for r in static_routines %}
{% if not r.collision_with %}
{{ r | pas_sig(is_var=False) | replace("; cdecl;", "; cdecl") }}
begin
  // TODO: Implement inline logic
  { Original C Declaration:
    {{ r.c_decl }}
  }
end;

{% endif %}
{% endfor %}
{% endif %}

end.
