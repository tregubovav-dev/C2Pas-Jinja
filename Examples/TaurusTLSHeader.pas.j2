unit TaurusTLSHeaders_{{ header.split('.')[0] }};

interface

uses
  IdCTypes,
  IdGlobal,
  {$IFDEF OPENSSL_STATIC_LINK_MODEL}
  TaurusTLSConsts,
  {$ENDIF}
  TaurusTLSHeaders_types,
  TaurusTLSHeaders_core;

{# --- MACROS FOR RECORD EXPANSION --- #}
{% set expand_records = True %}{# Control variable for record expansion #}

{% macro render_record_body(t) -%}
{% if t.fields %}
  record
  {% for f in t.fields %}
    {{ f | pas_field }}
  {% endfor %}
  end;
{% else %}
  record end;
{% endif %}
{%- endmacro %}

{% macro render_union_body(t) -%}
{% if t.fields %}
  record
    case Integer of
    {% for f in t.fields %}
      {{ loop.index0 }}: ( {{ f | pas_field }} );
    {% endfor %}
  end;
{% else %}
  record end;
{% endif %}
{%- endmacro %}

{% if types %}{# IF AT LEAST A TYPE DEFINITION EXISTS - DO GENERATE DECLARATION(S) #}
// =============================================================================
// TYPE DECLARATIONS
// =============================================================================
type
{% for t in types %}
    {% if t.collision_with %}{# Explicitly add a comment with case-sensitive collision  #}
  { TODO 1 -cID Collision detected : Review it and update. }
  // Collision with {{ t.collision_with }}:
  // {{ t.c_decl | replace('\n', '\n  // ') }}
{% else %}{# Otherwise generate type declaration #}
  {# Construct info objects for P-type (depth 1) and T-type (depth 0) #}
{% set p_info = {"name": t.name, "pointer_depth": 1} %}
{% set t_info = {"name": t.name, "pointer_depth": 0} %}
  {{ p_info | pas_type }} = ^{{ t_info | pas_type }};
{% if t.kind == "struct" %}
  {{ t_info | pas_type }} = {% if expand_records %}{{ render_record_body(t) }}{% else %}record end;{% endif %}
{% elif t.kind == "union" %}
  {{ t_info | pas_type }} = {% if expand_records %}{{ render_union_body(t) }}{% else %}record end;{% endif %}
{% elif t.kind == "alias" %}
  {{ t_info | pas_type }} = {{ t.parent_type | pas_type }};
{% endif %}
  {$EXTERNALSYM {{ p_info | pas_type }}}
{% endif %}

{% endfor %}
{% endif %}{# END OF TYPE DECLARATIONS SECTION #}
{% if enums %}{# IF AT LEAST AN ENUM DEFINITION EXISTS - DO GENERATE DECLARATION(S) #}

// =============================================================================
// ENUM TYPE DECLARATIONS
// =============================================================================
type
{% for enum_obj in enums %}
{% if enum_obj.collision_with %}
  // Collision with {{ enum_obj.collision_with }}: {{ enum_obj.name }}
{% else %}
  // Enum: {{ enum_obj.name }}
  {{ {"name": enum_obj.name, "pointer_depth": 0} | pas_type }} = (
{% for member in enum_obj['entries'] %}
    {{ member.name | pas_name }}{% if member.value is not none %} = {{ member.value }}{% endif %}{{ "," if not loop.last }}
{% endfor %}
  );

{% endif %}
{% endfor %}
{% endif %}{# END OF ENUM DECLARATIONS SECTION #}
{% if callbacks %}{# IF AT LEAST A CALLBACK DEFINITION EXISTS - DO GENERATE DECLARATION(S) #}

// =============================================================================
// CALLBACK TYPE DECLARATIONS
// =============================================================================
type
{% for c in callbacks %}
  {# Use pas_type at depth 0 to ensure the 'T' prefix is added #}
  {{ {"name": c.name, "pointer_depth": 0} | pas_type }} = {{ c | pas_sig(is_var=True) }};
{% endfor %}
{% endif %}{# END OF CALLBACK DECLARATIONS SECTION #}
{% if constants %}{# IF AT LEAST A CONSTANT DEFINITION EXISTS - DO GENERATE DECLARATION(S) #}

// =============================================================================
// CONSTANTS DECLARATIONS
// =============================================================================
const
{% for c in constants %}
  {{ c.name | pas_name }} = {{ c.value | pas_expression }};
{% endfor %}
{% endif %}{# END OF CONSTANT DECLARATIONS SECTION #}
{% if routines %}{# IF AT LEAST AN EXPORTED ROUTINE DEFINITION EXISTS - DO GENERATE PROCEDURAL VARIABLE AND EXTERNAL PROCEDURES DECLARATION(S) #}

{$IFNDEF OPENSSL_STATIC_LINK_MODEL}

// =============================================================================
// DYNMAIC BINDING VARIABLES
// =============================================================================
var

{% for r in routines if not r.is_macro and not r.is_inline %}
{% if not r.deprecated or r.deprecated | version_val > "1_1_0" | version_val %}
  {{ r.name }}: {{ r | pas_sig(is_var=True) }} = nil;{% if r.deprecated %} // Deprecated in {{ r.deprecated }}{% endif +%}
  {$EXTERNALSYM {{ r.name }}}

{% endif %}
{% endfor %}
{$ENDIF OPENSSL_STATIC_LINK_MODEL}

{$IFDEF OPENSSL_STATIC_LINK_MODEL}

// =============================================================================
// STATIC BINDING ROUTINES
// =============================================================================

{% for r in routines %}
{% if not r.deprecated or r.deprecated | version_val > "1_1_0" | version_val %}
{{ r | pas_sig }};{% if r.deprecated %} deprecated 'In OpenSSL {{ r.deprecated }}';{% endif +%}
{% endif %}
{% endfor %}
{$ENDIF OPENSSL_STATIC_LINK_MODEL}
{% endif %}{# END OF ROUTINES DECLARATIONS SECTION #}
{% if static_routines %}{# IF AT LEAST AN INLINE OR MACRO DEFINED ROUTINE DEFINITION EXISTS - DO GENERATE DECLARATION(S) #}

// =============================================================================
// INLINE OR MACRO ROUTINES
// =============================================================================

{% for r in static_routines %}
{{ r | pas_sig }};{% if r.deprecated %} deprecated 'In OpenSSL {{ r.deprecated }}';{% endif +%}
  {$IFDEF USE_INLINE}inline; {$ENDIF}

{% endfor %}
{% endif %}{# END OF INLINE OR MACRO DEFINED ROUTINES DECLARATIONS SECTION #}
{% if ossl_stacks %}{# IF AT LEAST A STACK DEFINITION EXISTS #}

// =============================================================================
// OPENSSL STACK DEFINITIONS
// =============================================================================
type
{% for s in ossl_stacks %}
  { TODO 1 -copenssl stack {{ s.name }} definitions : To replace placeholder body with the actual type and callbacks. }
  PSTACK_OF_{{ s.name }} = Pointer;
  {$EXTERNALSYM PSTACK_OF_{{ s.name }}}

  { Original Stack Macros for {{ s.name }}:
  {% for d in s.decls %}
    {{ d | replace('\n', '\n    ') }}
  {% endfor %}
  }

{% endfor %}
{% endif %}{# END OF OSSL_STACKS DEFINED ROUTINES DECLARATIONS SECTION #}

implementation
{% if routines or static_routines %}

uses
  {$IFNDEF OPENSSL_STATIC_LINK_MODEL}
  classes,
  TaurusTLSLoader,
  {$ENDIF}
  TaurusTLS_ResourceStrings,
  TaurusTLSExceptionHandlers;
{% endif %}
{% if routines %}

{$IFDEF OPENSSL_STATIC_LINK_MODEL}

// =============================================================================
// STATIC BINDING ROUTINES IMPORTS
// =============================================================================

{% for r in routines %}
{% if not r.deprecated or r.deprecated | version_val > "1_1_0" | version_val %}
{{ r | pas_sig }} external CLibCrypto name '{{ r.name }}';
{% endif %}
{% endfor %}
{$ENDIF}

// =============================================================================
// DYNAMIC BINDING ROUTINES CONSTANTS
// =============================================================================

const
{% for r in routines %}
{% set v_intro = r.introduced | version_val %}
{% set v_deprec = r.deprecated | version_val if r.deprecated else 0 %}
{% if not r.deprecated or v_deprec > "1_1_0" | version_val %}

  {{ r.name }}_procname = '{{ r.name }}';
{% if r.introduced %}
{% if v_deprec == 0 or v_deprec > v_intro %}
  {{ r.name }}_introduced = {{ r.introduced | pas_version }};
{% elif v_deprec < v_intro %}
  {{ r.name }}_introduced = {{ r.introduced | pas_version }}; {$MESSAGE Warn 'Incorrect "Introduced/Deprecated version"'}
{% endif %}
{% endif %}
{% if r.deprecated %}
  {{ r.name }}_removed = {{ r.deprecated | pas_version }};
{% endif %}
{% endif %}
{% endfor %}
{% endif %}

{% if static_routines %}
// =============================================================================
// INLINE/MACRO IMPLEMENTATIONS
// =============================================================================

{% for r in static_routines %}
{{ r | pas_sig | replace("; cdecl;", "; cdecl") }}
begin
 { TODO 1 -copenssl inline routines : To replace placeholder body with the actual code. }
  // This is an inline routine or macro. Manual implementation required if needed.
  { Original C Declaration:
    {{ r.c_decl }}
  }
end;

{% endfor %}
{% endif %}
{% if routines or static_routines %} 

// =============================================================================
// FORWARD and REMOVE COMPATIBILITY IMPLEMENTATIONS
// =============================================================================

{ TODO 1 -cinline forrward and remove compatibility routines : To add required procedures/functions. }

// =============================================================================
// ERRORS STUBS
// =============================================================================

{% for r in routines %}
{% if not r.deprecated or r.deprecated | version_val > "1_1_0" | version_val %}
{{ r | pas_sig(prefix="ERR_") | replace("; cdecl;", "; cdecl") }}
begin
  ETaurusTLSAPIFunctionNotPresent.RaiseException({{ r.name }}_procname);
end;

{% endif %}
{% endfor %}
{% endif %}
{% if routines %} 

{$IFNDEF OPENSSL_STATIC_LINK_MODEL}
procedure Load(const ADllHandle: TIdLibHandle; LibVersion: TIdC_UINT;
  const AFailed: TStringList);
var
  FuncLoadError: Boolean;
begin
{% for r in routines %}
{% if not r.deprecated or r.deprecated | version_val > "1_1_0" | version_val %}
  {{ r.name }} := LoadLibFunction(ADllHandle, {{ r.name }}_procname);
  FuncLoadError := not assigned({{ r.name }});
  if FuncLoadError then
  begin
    {$if not defined({{ r.name }}_allownil)}
    {{ r.name }} := ERR_{{ r.name }};
    {$ifend}
    {$if declared({{ r.name }}_introduced)}
    if LibVersion < {{ r.name }}_introduced then
    begin
      {$if declared(FC_{{ r.name }})}
      {{ r.name }} := FC_{{ r.name }};
      {$ifend}
      FuncLoadError := false;
    end;
    {$ifend}
    {$if declared({{ r.name }}_removed)}
    if {{ r.name }}_removed <= LibVersion then
    begin
      {$if declared(_{{ r.name }})}
      {{ r.name }} := _{{ r.name }};
      {$ifend}
      FuncLoadError := false;
    end;
    {$ifend}
    {$if not defined({{ r.name }}_allownil)}
    if FuncLoadError then
      AFailed.Add('{{ r.name }}');
    {$ifend}
  end;
{% endif %}
  
{% endfor %}
end;

procedure Unload;
begin
{% for r in routines %}
{% if not r.deprecated or r.deprecated | version_val > "1_1_0" | version_val %}
  {{ r.name }} := nil;
{% endif %}
{% endfor %}
end;
{$ENDIF}

{$IFNDEF OPENSSL_STATIC_LINK_MODEL}
initialization
  Register_SSLLoader(Load,'LibCrypto');
  Register_SSLUnloader(Unload);
{$ENDIF}
{% endif %}
end.
