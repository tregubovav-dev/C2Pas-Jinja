unit {{ header.split('.')[0] }};

interface

uses
  IdCTypes,
  IdGlobal,
  {$IFDEF OPENSSL_STATIC_LINK_MODEL}
  TaurusTLSConsts,
  {$ENDIF}
  TaurusTLSHeaders_types,
  TaurusTLSHeaders_core;

{# --- FILTER TYPES --- #}
{% set filtered_types = types | list %}
{% if filtered_types %}
type
  {% for t in filtered_types %}
  P{{ t.name }} = Pointer;
  {$EXTERNALSYM P{{ t.name }}}
  {% endfor %}
{% endif %}

{# --- EXCLUDE CONSTANTS WITH 'OBJ_' PREFIX (USING REGEX) --- #}
{% set filtered_consts = constants | rejectattr("name", "match", "^OBJ_") | list %}
{% if filtered_consts %}
const
  {% for c in filtered_consts %}
  {{ c.name | pas_name }} = {{ c.value | pas_expression }};
  {% endfor %}
{% endif %}

implementation

end.